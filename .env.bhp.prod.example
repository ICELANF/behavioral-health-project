# ============================================================
# BHP 行健平台 — 生产服务器环境变量模板
#
# 部署步骤:
#   1. 复制此文件: cp .env.bhp.prod.example .env.bhp
#   2. 填写所有 ★ 必填项 (搜索 CHANGE_ME)
#   3. docker-compose -f docker-compose.yml up -d
# ============================================================

# ---- 应用 ----
ENVIRONMENT=production
LOG_LEVEL=INFO

# ---- 数据库 ★ 必须修改密码 ----
# 注意: docker-compose.yml 中 db 服务也要改 POSTGRES_PASSWORD
DATABASE_URL=postgresql+asyncpg://bhp_user:CHANGE_ME_STRONG_PASSWORD@db:5432/bhp_db

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ---- Ollama (Linux 服务器 — Docker 默认网关) ----
# 若 Ollama 运行在宿主机，使用 172.17.0.1 (Linux Docker 默认网关)
OLLAMA_API_URL=http://172.17.0.1:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest
EMBEDDING_DIMENSION=1024

# ---- JWT 签名密钥 ★ 必须更换为强随机密钥 ----
# 生成命令: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_BASE64_48
JWT_ALGORITHM=HS256

# ---- WeChat 小程序 ★ 必填 ----
WECHAT_APP_ID=wx7da71ddbc7890598
WECHAT_APP_SECRET=CHANGE_ME_WECHAT_SECRET

# ---- 告警邮件 (可选) ----
ALERT_EMAIL_SMTP=smtp.qq.com
ALERT_EMAIL_PORT=465
ALERT_EMAIL_USER=your@qq.com
ALERT_EMAIL_PASS=your_smtp_password
ALERT_EMAIL_TO=your@qq.com

# ---- CORS 允许域名 ----
CORS_ORIGINS=https://api.xingjian.health

# ---- 云 LLM (可选，无则降级本地 Ollama) ----
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_API_KEY=
CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
CLOUD_LLM_MODEL=deepseek-chat
